# Bearer token your AI agent uses to call the MCP endpoint. Generate a long random string.
GETSMS_MCP_API_KEY=change-me-to-a-long-random-string

# Your phones. Each needs a unique label and a unique random ingest token.
# The token goes into that phone's forwarding automation URL: /ingest/<token>
GETSMS_DEVICES=[{"label":"主力机-138xxxx","token":"change-me-device-1-token"}]

# Optional overrides (defaults shown):
# GETSMS_PORT=3000
# GETSMS_DB_PATH=./data/getsms.db
# GETSMS_WINDOW_MINUTES=10
# GETSMS_CODE_INDICATORS=验证码,verification code,verification,code,OTP,one-time,passcode
